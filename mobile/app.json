{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.verikarya.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "VeriKarya requires camera access to capture face verification snapshots when punching attendance or submitting task evidence.",
        "NSLocationWhenInUseUsageDescription": "VeriKarya requires GPS location access to check if you are within the circular geofence of target field client sites."
      }
    },
    "android": {
      "package": "com.verikarya.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#2563EB",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/b4cfa7f6-1131-4ecf-8d76-34e082c75c0b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b4cfa7f6-1131-4ecf-8d76-34e082c75c0b"
      }
    }
  }
}
